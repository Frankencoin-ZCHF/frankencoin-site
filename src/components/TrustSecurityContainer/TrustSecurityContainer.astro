---
import { getLanguageFromURL, loadContent, getLocalizedPath } from "../../utils/i18n";
import { fetchXerberusRatings } from '../../utils/xerberus';

const currentLang = getLanguageFromURL(Astro.url.pathname);
const index = await loadContent("index", currentLang);
const compliancePath = getLocalizedPath('/compliance', currentLang);

const xerberusRatings = await fetchXerberusRatings();
const ratingsByKey = new Map(xerberusRatings.map((r) => [`${r.type}:${r.id}`, r]));

const RATING_CARDS = [
  { type: 'protocol', id: 'frankencoin', name: 'Frankencoin', subtitle: 'Protocol', logo: '/images/Frankencoin-Logo-Compressify.io.webp' },
  { type: 'organisation', id: 'frankencoin-dao', name: 'Frankencoin', subtitle: 'DAO', logo: '/images/FPS-Logo-Compressify.io.webp' },
  { type: 'pool', id: 'frankencoin-savings-eth', name: 'Frankencoin Savings', subtitle: 'Ethereum Vault', logo: '/images/Coin_Logo_Frankencoin_saved.svg' },
];

function scoreColor(score: number | null): string {
  if (score == null) return 'text-[var(--color-neutral-400)]';
  if (score >= 70) return 'text-green-600';
  if (score >= 40) return 'text-amber-500';
  return 'text-red-600';
}
---

<div class="space-y-16 max-w-5xl mx-auto">
  <!-- Regulatory Section -->
  <div class="space-y-6">
    <h3 class="ty-big-2">{index.trust_security.regulatory.title}</h3>
    <p class="ty-body-1">{index.trust_security.regulatory.description}</p>

    <!-- Learn More Link -->
    <div class="mt-6">
      <a
        href={compliancePath}
        class="inline-flex items-center gap-2 bg-[var(--color-brand-deep-blue)] text-white px-6 py-3 rounded-lg ty-regular font-bold hover:bg-[var(--color-brand-swiss)] transition-colors"
      >
        <span>{index.trust_security.regulatory.learnMoreLabel}</span>
        <img src="/images/Arrow.svg" loading="lazy" alt="" class="w-3 h-3 invert" />
      </a>
    </div>

    <!-- Direct PDF Links -->
    <div class="flex flex-col md:flex-row gap-6 mt-6">
      {index.trust_security.regulatory.documents.map((doc) => (
        doc.href ? (
          <a
            href={doc.href}
            target="_blank"
            rel="noopener noreferrer"
            class="ty-regular text-[var(--color-brand-deep-blue)] hover:underline inline-flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span>{doc.label}</span>
          </a>
        ) : (
          <span class="ty-regular text-[var(--color-brand-titan-gray)] italic">
            {doc.label}
          </span>
        )
      ))}
    </div>
  </div>

  <!-- Audits Section -->
  <div class="space-y-6">
    <h3 class="ty-big-2">{index.trust_security.audits.title}</h3>
    <p class="ty-body-1">{index.trust_security.audits.description}</p>
    <div class="flex flex-wrap justify-center md:justify-start gap-8 mt-8">
      {index.trust_security.audits.partners.map((partner) => (
        <a href={partner.href} target="_blank" rel="noopener noreferrer" class="block">
          <div class="flex flex-col items-center">
            <img
              class="w-[150px] md:w-[180px] hover:scale-110 transition"
              src={partner.image}
              alt={partner.altText}
              height="40"
              loading="lazy"
            />
            {partner?.sublinks && (
              <div class="flex gap-4 mt-3">
                {partner.sublinks.map((sublink) => (
                  <a
                    href={sublink.href}
                    class="ty-small text-[var(--color-brand-titan-gray)] hover:text-[var(--color-brand-swiss)] hover:underline font-bold"
                    target="_blank"
                  >
                    {sublink.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Ratings Section -->
  <div class="space-y-8">
    <h3 class="ty-big-2">{index.trust_security.ratings.title}</h3>
    <p class="ty-body-1">
      {index.trust_security.ratings.independentlyRatedBy}&nbsp;<img
        src="/images/xerberus-logo.svg"
        alt="Xerberus"
        class="h-4 w-4 inline-block align-middle"
        loading="lazy"
      />&nbsp;<a
        href="https://xerberus.io/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-brand-swiss)] hover:underline font-semibold"
      >Xerberus</a>,&nbsp;{index.trust_security.ratings.description}
    </p>

    <!-- Feature cards -->
    <div class="grid md:grid-cols-3 gap-4">
      {index.trust_security.ratings.features.map((feature: any, i: number) => (
        <div class="bg-white rounded-xl p-6 border border-[var(--color-neutral-200)]">
          <div class="w-10 h-10 rounded-full bg-[var(--color-brand-deep-blue)] flex items-center justify-center mb-4 text-white">
            {i === 0 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M11.484 2.17a.75.75 0 011.032 0 11.209 11.209 0 007.877 3.08.75.75 0 01.722.515 12.74 12.74 0 01.635 3.985c0 5.942-4.064 10.933-9.563 12.348a.749.749 0 01-.374 0C6.314 20.683 2.25 15.692 2.25 9.75c0-1.39.223-2.73.635-3.985a.75.75 0 01.722-.516l.143.001c2.996 0 5.717-1.17 7.734-3.08z" clip-rule="evenodd" /></svg>}
            {i === 1 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.25 4.533A9.707 9.707 0 006 3a9.735 9.735 0 00-3.25.555.75.75 0 00-.5.707v14.25a.75.75 0 001 .707A8.237 8.237 0 016 18.75c1.995 0 3.823.707 5.25 1.886V4.533zM12.75 20.636A8.214 8.214 0 0118 18.75c.966 0 1.89.166 2.75.47a.75.75 0 001-.708V4.262a.75.75 0 00-.5-.707A9.735 9.735 0 0018 3a9.707 9.707 0 00-5.25 1.533v16.103z" /></svg>}
            {i === 2 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M19.902 4.098a3.75 3.75 0 00-5.304 0l-4.5 4.5a3.75 3.75 0 001.035 6.037.75.75 0 01-.646 1.353 5.25 5.25 0 01-1.449-8.45l4.5-4.5a5.25 5.25 0 117.424 7.424l-1.757 1.757a.75.75 0 11-1.06-1.06l1.757-1.757a3.75 3.75 0 000-5.304zm-7.389 4.267a.75.75 0 011 .353 5.25 5.25 0 011.449 8.45l-4.5 4.5a5.25 5.25 0 11-7.424-7.424l1.757-1.757a.75.75 0 111.06 1.06l-1.757 1.757a3.75 3.75 0 105.304 5.304l4.5-4.5a3.75 3.75 0 00-1.035-6.037.75.75 0 01-.353-1z" clip-rule="evenodd" /></svg>}
          </div>
          <h4 class="ty-regular font-bold text-[var(--color-brand-deep-blue)] mb-2">{feature.title}</h4>
          <p class="ty-body-2 text-[var(--color-brand-titan-gray)]">{feature.description}</p>
        </div>
      ))}
    </div>

    <!-- Rating score cards -->
    <div class="grid md:grid-cols-3 gap-4">
      {RATING_CARDS.map((card) => {
        const rating = ratingsByKey.get(`${card.type}:${card.id}`);
        const score = rating?.score ?? null;
        return (
          <div class="bg-white rounded-xl p-6 border border-[var(--color-neutral-200)] space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-[var(--color-neutral-100)] flex items-center justify-center overflow-hidden shrink-0">
                <img src={card.logo} alt={card.name} class="w-7 h-7 object-contain" loading="lazy" />
              </div>
              <div>
                <p class="ty-regular font-bold text-[var(--color-brand-deep-blue)] leading-tight">{card.name}</p>
                <p class="ty-small text-[var(--color-brand-titan-gray)]">{card.subtitle}</p>
              </div>
            </div>
            <div class="flex items-baseline gap-2">
              <span class={`text-5xl font-bold ${scoreColor(score)}`}>
                {score != null ? `${Math.round(score)}%` : 'n/a'}
              </span>
              {score != null && <span class="ty-small text-[var(--color-brand-titan-gray)]">{index.trust_security.ratings.ratingLabel}</span>}
            </div>
            <a
              href={`https://app.xerberus.io/${card.type}/${card.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 ty-small font-semibold text-[var(--color-brand-swiss)] hover:underline"
            >
              {index.trust_security.ratings.viewReportLabel}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        );
      })}
    </div>
  </div>
</div>
